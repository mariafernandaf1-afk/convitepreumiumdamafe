body {
  margin: 0;
  font-family: Arial;
  background: black;
  color: white;
  text-align: center;
  overflow-x: hidden;
}

/* ✨ ESTRELAS ANIMADAS */
.stars {
  position: fixed;
  width: 100%;
  height: 100%;
  background: radial-gradient(white 1px, transparent 1px);
  background-size: 3px 3px;
  opacity: 0.15;
  animation: move 20s linear infinite;
}

@keyframes move {
  from {transform: translateY(0);}
  to {transform: translateY(-200px);}
}

/* TELAS */
.tela {display:none;padding:40px;}
.ativa {display:block;}

/* ENVELOPE */
.envelope {
  font-size: 110px;
  margin: 60px 0;
  cursor: pointer;
  filter: drop-shadow(0 0 15px silver);
  transition: 0.4s;
}

.envelope:hover {
  transform: scale(1.15) rotate(-3deg);
}

/* DISCO GIRANDO */
.discos::before {
  content: "🪩 🪩 🪩";
  display: block;
  margin-top: 20px;
  animation: float 3s infinite ease-in-out;
}

@keyframes float {
  0%,100%{transform:translateY(0);}
  50%{transform:translateY(-12px);}
}

/* CARD */
.card {
  background: rgba(10,10,10,0.9);
  border: 1px solid rgba(192,192,192,0.3);
  border-radius: 20px;
  padding: 30px;
  max-width: 420px;
  margin: auto;
  box-shadow: 0 0 40px rgba(192,192,192,0.2);
  backdrop-filter: blur(10px);
}

/* nome */
.nome {
  font-size: 45px;
  letter-spacing: 4px;
}

.idade {
  font-size: 110px;
  color: silver;
  text-shadow: 0 0 20px silver;
}

.foto {
  width: 130px;
  border-radius: 12px;
  border: 2px solid silver;
  margin: 15px 0;
}

.data {
  color: #ccc;
}

/* BOX */
.box {
  margin: 15px 0;
  padding: 12px;
  background: rgba(255,255,255,0.05);
  border-radius: 12px;
}

/* BOTÃO */
.btn {
  display:inline-block;
  margin-top:10px;
  padding:10px 15px;
  background:silver;
  color:black;
  border-radius:10px;
  text-decoration:none;
  font-weight:bold;
}

.green {
  background:#25D366;
  color:white;
}

.final {
  margin-top:20px;
  color:#ccc;
}